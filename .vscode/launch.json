{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "data-service",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/data-service/cmd/main.go",
            "env": {
                "DATABASE_URL": "postgres://fund_app:pass@localhost:5432/fund_db",
                "GRPC_PORT": "9090"
            },
            "console": "integratedTerminal"
        },
        {
            "name": "search-service",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/search-service/cmd/main.go",
            "env": {
                "DATABASE_URL": "postgres://fund_app:pass@localhost:5432/fund_db",
                "GRPC_PORT": "9091",
                "DATA_SERVICE_ADDR": "localhost:9090"
            },
            "console": "integratedTerminal"
        }
    ],
    "compounds": [
        {
            "name": "Run All Services",
            "configurations": ["data-service", "search-service"],
            "stopAll": true
        }
    ]
}